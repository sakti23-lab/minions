# All optional — defaults work for local development
PORT=6969                               # Server port (default: 6969)
HERMES_PYTHON=                          # Path to Python with Hermes deps (auto-detected if unset)
HERMES_AGENT_DIR=~/.hermes/hermes-agent # Path to Hermes agent installation
HERMES_AGENT_RUN_LIMIT=10               # Max concurrent agent runs in Python worker
HEARTBEAT_CONCURRENCY=2                 # Concurrent heartbeat checks
MINIONS_HOME=~/.minions                 # Minions home directory (local development)
DB_PATH=~/.minions/data/minions.db      # SQLite database path (local development)

# Production deployment settings (Docker/Kubernetes)
NODE_ENV=production                     # Set to 'production' for optimized deployments
HOME=/app/data                          # Home directory for app data (must match Dockerfile ENV HOME)
MINIONS_HOME=/app/data/.minions         # Minions home directory (Docker)
DB_PATH=/app/data/.minions/minions.db   # SQLite database path (Docker)
